APP_ENV=dev
# prod - for deployment; dev - local
APP_HOST=0.0.0.0
APP_PORT=8000
# Docker: общая БД для api и bot. POSTGRES_PASSWORD должен совпадать в db и api.
# POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/botdb
# Локальный запуск бота при API в Docker: раскомментируйте и укажите вместо строки выше
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/botdb
JWT_SECRET=change-me
JWT_EXPIRES_MINUTES=480
CSRF_SECRET=dev-csrf
BOT_TOKEN=replace-with-telegram-bot-token
# Username менеджера без @ (для кнопки "Написать менеджеру")
MANAGER_USERNAME=manager_username
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=change-me
UPLOAD_DIR=./uploads
# Публичный URL загрузок при локальном хранении (бот отправляет медиа по этой ссылке)
UPLOAD_BASE_URL=http://localhost:8000/uploads
# Обязательно для бота в Docker/проде: медиа в контенте (Акции, Новинки, Мероприятия) и в рассылке по контент-плану.
# Telegram скачивает файл по этому URL; localhost и внутренние хосты (api, minio) не доступны с интернета.
# Укажите публичный origin (схема + хост:порт без пути): API — http://ВАШ_IP:8000, MinIO — http://ВАШ_IP:9000
# UPLOAD_PUBLIC_BASE_URL=http://192.168.1.100:8000
MAX_UPLOAD_MB=5
# --- Медиа на Timeweb S3 (https://s3.twcstorage.ru). Рекомендуется для прода. ---
# Задайте эти переменные в .env на сервере — deploy автоматически подставит s3-external (без MinIO).
# S3_ENDPOINT_URL=https://s3.twcstorage.ru
# S3_BUCKET=your-bucket-name
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...
# S3_REGION=ru-1
# S3_PUBLIC_BASE_URL=https://s3.twcstorage.ru/your-bucket-name

# MinIO (локальный S3 в docker-compose) — если не используете внешний S3
# MINIO_ROOT_USER=minioadmin
# MINIO_ROOT_PASSWORD=minioadmin
# S3_PUBLIC_BASE_URL=http://147.45.96.211:9000/uploads
TIMEZONE=Europe/Moscow
ALLOWED_ORIGINS=http://localhost:5173
# Production: ALLOWED_ORIGINS=http://147.45.96.211,https://your-domain.com
