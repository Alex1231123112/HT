FROM node:20-alpine AS build
ARG VITE_CSRF_TOKEN=dev-csrf
ENV VITE_CSRF_TOKEN=$VITE_CSRF_TOKEN
WORKDIR /app
COPY admin/frontend/package.json ./
RUN npm install
COPY admin/frontend .
RUN npm run build

FROM nginx:stable-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
# Запросы к /api идут через nginx на backend — один origin, без CORS
RUN sed -i 's|http://localhost:8000/api|/api|g' /usr/share/nginx/html/index.html
